{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/optimize-images.cjs",
    "build": "vite build",
    "postbuild": "node scripts/postbuild.cjs",
    "prerender": "react-snap",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "capture:cases": "node scripts/capture-cases.cjs",
    "optimize:images": "node scripts/optimize-images.cjs"
  },
  "reactSnap": {
    "source": "dist",
    "destination": "dist",
    "inlineCss": false,
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox"
    ],
    "include": [
      "/",
      "/company",
      "/services",
      "/services/professional-websites",
      "/services/full-stack-development",
      "/services/on-demand-team",
      "/services/legacy-migration",
      "/services/automation",
      "/services/ai-solutions",
      "/services/mobile-apps",
      "/services/ecommerce",
      "/services/support",
      "/contact",
      "/blog",
      "/cases",
      "/cases/sentra",
      "/cases/atep-inventory",
      "/cases/turnos",
      "/cases/lnh-partner",
      "/cases/tibis-market",
      "/cases/hampton-textile-printing",
      "/cases/luis-royuela-nutricionistas",
      "/privacy-policy",
      "/cookies-policy",
      "/legal-notice"
    ]
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/newsreader": "^5.2.10",
    "@supabase/supabase-js": "^2.57.4",
    "@vercel/analytics": "^1.5.0",
    "emailjs-com": "^3.2.0",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-google-recaptcha-v3": "^1.11.0",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^7.9.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "puppeteer": "^25.1.0",
    "react-snap": "^1.23.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2"
  }
}
